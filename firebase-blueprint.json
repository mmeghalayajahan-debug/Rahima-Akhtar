{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a student or admin in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Represents an Islamic course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string", "enum": ["Quran learning", "Dua", "Namaz", "Hadith", "Basic Islam"] },
        "description": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "videoUrl": { "type": "string", "format": "uri" },
              "duration": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "description"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Tracks student progress in a course.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "progress": { "type": "number" },
        "completed": { "type": "boolean" },
        "lastAccessed": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId"]
    },
    "Review": {
      "title": "Review",
      "description": "Student reviews for the madrasa or courses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "comment"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Available courses"
    },
    "/enrollments/{enrollmentId}": {
      "schema": "Enrollment",
      "description": "Course enrollments and progress"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Public reviews"
    }
  }
}
